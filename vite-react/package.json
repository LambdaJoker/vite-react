{
  "name": "my-blog-monorepo",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter vite-react dev",
    "dev:server": "pnpm --filter server start",
    "dev:full": "pnpm --parallel --stream run /^dev/",
    "build": "pnpm --filter server run prisma:generate && pnpm --filter server exec prisma db push --accept-data-loss && pnpm --filter vite-react build",
    "vercel-build": "pnpm --filter vite-react build",
    "postinstall": "pnpm --filter server run prisma:generate"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "dependencies": {
    "dotenv": "^16.5.0",
    "mysql2": "^3.14.1"
  }
}