{
  "name": "my-blog-monorepo",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter client dev",
    "dev:server": "pnpm --filter server start",
    "dev:full": "pnpm --parallel --stream run /^dev/",
    "build": "pnpm --filter server db:init && pnpm --filter client build",
    "vercel-build": "pnpm --filter client build",
    "postinstall": "pnpm --filter server run prisma:generate"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}