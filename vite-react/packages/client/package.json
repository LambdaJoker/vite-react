    "@mui/material": "^7.0.2",
    "axios": "^1.7.9",
    "framer-motion": "^12.4.10",
    "github-markdown-css": "^5.9.0",
    "helmet": "^8.1.0",
    "katex": "^0.17.0",
    "mermaid": "^11.15.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-helmet-async": "^2.0.5",
    "react-hook-form": "^7.71.2",
    "react-icons": "^5.6.0",
    "react-markdown": "^10.1.0",
    "react-mde": "^11.5.0",
    "react-router-dom": "^6.30.1",
    "react-syntax-highlighter": "^16.1.1",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
