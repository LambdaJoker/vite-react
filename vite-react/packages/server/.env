# 背景壁纸获取模式 (Wallpaper Mode)
# 可选值: 
#   local  - 本地随机模式，从已有的 wallpapers-data.json 中随机读取 (默认，不实时抓取)
#   scrape - 实时获取模式，会定时抓取新壁纸并补充到本地
#   vedio  - 视频模式，返回设定的视频作为背景
WALLPAPER_MODE=vedio
