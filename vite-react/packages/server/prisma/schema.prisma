generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model articles {
  id         Int       @id @default(autoincrement())
  title      String    @db.VarChar(255)
  excerpt    String?   
  content    String?   
  image      String?   @db.VarChar(255)
  author     String?   @default("Admin") @db.VarChar(100)
  read_count Int       @default(0) 
  category   String?   @db.VarChar(100)
  tags       Json?
  date       DateTime  @default(now()) @db.Timestamp(3)
  created_at DateTime? @default(now()) @db.Timestamp(3)
  updated_at DateTime? @default(now()) @db.Timestamp(3)

  @@index([category], map: "idx_category")
  @@index([date], map: "idx_date")
}

model skill_categories {
  category_id              Int                        @id @default(autoincrement())
  category_name            String                     @unique(map: "category_name") @db.VarChar(50)
  created_at               DateTime?                  @db.Timestamp(3)
  updated_at               DateTime?                  @db.Timestamp(3)
  skill_category_relations skill_category_relations[]
}

model skill_category_relations {
  relation_id      Int              @id @default(autoincrement())
  skill_id         Int
  category_id      Int
  skills           skills           @relation(fields: [skill_id], references: [skill_id], onDelete: Cascade, onUpdate: NoAction, map: "skill_category_relations_ibfk_1")
  skill_categories skill_categories @relation(fields: [category_id], references: [category_id], onDelete: Cascade, onUpdate: NoAction, map: "skill_category_relations_ibfk_2")

  @@unique([skill_id, category_id], map: "uniq_skill_category")
  @@index([category_id], map: "idx_category")
  @@index([skill_id], map: "idx_skill")
}

model skills {
  skill_id                 Int                        @id @default(autoincrement())
  skill_name               String                     @unique(map: "skill_name") @db.VarChar(100)
  proficiency              Int                        @default(0) 
  icon                     String                     @default("") @db.VarChar(50)
  description              String?                    
  projects                 String?                    
  created_at               DateTime?                  @db.Timestamp(3)
  updated_at               DateTime?                  @db.Timestamp(3)
  skill_category_relations skill_category_relations[]

  @@index([proficiency], map: "idx_proficiency")
  @@index([skill_name], map: "idx_skill_name")
}
